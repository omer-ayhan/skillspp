{
  "name": "skillspp-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "skillspp": "corepack pnpm --filter @skillspp/skillspp-cli skillspp",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test:unit": "bash ./scripts/check-boundaries.sh && turbo run test:unit",
    "test:integration": "bash ./scripts/check-boundaries.sh && turbo run test:integration",
    "test:contract": "bash ./scripts/check-boundaries.sh && turbo run test:contract",
    "test:e2e": "bash ./scripts/check-boundaries.sh && turbo run test:e2e",
    "test:ci": "bash ./scripts/check-boundaries.sh && turbo run test:ci",
    "test": "corepack pnpm run test:ci",
    "lint": "bash ./scripts/check-boundaries.sh && turbo run lint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "pnpm": "10.18.3",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
